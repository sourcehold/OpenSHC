{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenSHC.dll",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/_original/Stronghold Crusader.exe",
      "args": ["--ucp-verbosity", "2", "--ucp-console-verbosity", "2"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/_original",
      "preLaunchTask": "CMake: Prepare OpenSHC.dll Debug"
    },
    {
      "name": "Debug ghidra export",
      "type": "debugpy",
      "request": "launch",
      "program": "tools/import/ghidra-importer.py",
      "console": "integratedTerminal",
      "args": "--sarif 'Stronghold Crusader.exe.sarif' --output-dir 'src' --overwrite-all --verbose"
    },
    {
      "name": "Debug ghidra function rewriter",
      "type": "debugpy",
      "request": "launch",
      "program": "tools/mcp/ghidra_scripts/functionrewriter/__main__.py",
      "console": "integratedTerminal",
      "args": ""
    }
  ]
}
